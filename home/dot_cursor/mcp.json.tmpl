{
  "mcpServers": {
{{- /* Eligible servers + resolved args come from the shared prep partial. */ -}}
{{- $eligible := includeTemplate ".chezmoitemplates/mcp-eligible-servers.tmpl" (dict "ctx" . "target" "cursor") | fromJson -}}
{{- $first := true -}}
{{- range $serverId := (keys $eligible | sortAlpha) -}}
  {{- $server := index $eligible $serverId -}}
  {{- if hasKey $server "local" -}}
    {{- $cursorCommand := $server.local.command -}}
    {{- $cursorArgs := $server.local.args -}}
    {{- $cursorEnv := (default (dict) $server.local.env) -}}
    {{- if $first }}{{- $first = false }}{{ else }},{{ end }}
    "{{ $serverId }}": {
      "command": "{{ $cursorCommand }}",
      "env": {{ $cursorEnv | toPrettyJson "      " }},
      "args": {{ $cursorArgs | toPrettyJson "      " }}
    }
  {{- else if hasKey $server "remote" -}}
    {{- $cursorTransport := "streamableHttp" -}}
    {{- if hasKey $server.remote "transport" -}}
      {{- $cursorTransport = $server.remote.transport -}}
    {{- end -}}
    {{- $cursorHeaders := dict -}}
    {{- if hasKey $server.remote "headers" -}}
      {{- $cursorHeaders = $server.remote.headers -}}
    {{- end -}}
    {{- if $first }}{{- $first = false }}{{ else }},{{ end }}
    "{{ $serverId }}": {
      "transport": "{{ $cursorTransport }}",
      "url": "{{ $server.remote.url }}",
      "headers": {{ $cursorHeaders | toPrettyJson "      " }}
    }
  {{- end -}}
{{- end }}
  }
}
