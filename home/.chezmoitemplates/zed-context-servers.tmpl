{{- /* Render Zed context_servers (eligible servers + resolved args from shared partial). */ -}}
{{- $eligible := includeTemplate ".chezmoitemplates/mcp-eligible-servers.tmpl" (dict "ctx" . "target" "zed") | fromJson -}}
{{- $first := true -}}
{{- range $serverId := (keys $eligible | sortAlpha) -}}
  {{- $server := index $eligible $serverId -}}
  {{- if $first }}{{- $first = false }}{{ else }},{{ end }}
  "{{ $serverId }}": {
    {{- if hasKey $server "local" -}}
    "enabled": true,
    "remote": false,
    "command": {{ $server.local.command | toJson }},
    "args": {{ $server.local.args | toPrettyJson | indent 4 | trim }},
    "env": {{ default (dict) $server.local.env | toPrettyJson | indent 4 | trim }}
    {{- else if hasKey $server "remote" -}}
    "enabled": true,
    "url": {{ $server.remote.url | toJson }}{{ if hasKey $server.remote "headers" }},
    "headers": {{ $server.remote.headers | toPrettyJson | indent 4 | trim }}{{ end }}
    {{- end -}}
  }
{{- end }}
