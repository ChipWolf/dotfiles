{{- $chocoPackages := includeTemplate ".chezmoitemplates/overlay-flatten.tmpl" (dict "ctx" . "area" "chocolatey" "key" "packages") | fromJson -}}
{{- /*
  CI exclusions: chocolatey packages that fail or hang on a headless GitHub
  Actions windows-2025 runner. Confirmed against PR #78 runs:

  - gnupg            blocks on the GnuPG setup dialog (orphan-process termination
                     of gnupg-w32-* after the 6h job timeout).
  - powershell-core  install errors with `(InconsistentInstallerState) Attempt
                     to install host that is currently running` because pwsh is
                     the interpreter running the workflow step.
  - treesizefree    chocolateyInstall.ps1 errors during install.

  These aren't needed for the chezmoi managed / Verify checks.
*/ -}}
{{- $ciExclude := list "gnupg" "powershell-core" "treesizefree" -}}
{{- $isCi := and (hasKey . "ci") .ci -}}
<?xml version="1.0" encoding="utf-8"?>
<packages>
{{- range $pkg := uniq $chocoPackages -}}
  {{- if and $isCi (has $pkg $ciExclude) }}
  <!-- {{ $pkg }} skipped under CI -->
  {{- else }}
  <package id="{{ $pkg }}" />
  {{- end -}}
{{- end }}
</packages>
