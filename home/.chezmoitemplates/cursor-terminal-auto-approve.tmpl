{{- /* Render bash permission rules as Cursor chat.tools.terminal.autoApprove (allow=true, deny=false).
       Collected + per-rule gated rules come from the shared prep partial.
       Cursor uses the loose gate (absent condition key includes the rule). */ -}}
{{- $rules := includeTemplate ".chezmoitemplates/agent-permission-rules.tmpl" (dict "ctx" . "gate" "loose") | fromJson -}}

{{- $first := true -}}
{{- range $rule := $rules -}}
  {{- if and (eq $rule.kind "bash") (ne $rule.pattern "*") -}}
    {{- $value := "" -}}
    {{- if eq $rule.op "allow" -}}{{- $value = "true" -}}{{- end -}}
    {{- if eq $rule.op "deny" -}}{{- $value = "false" -}}{{- end -}}
    {{- if ne $value "" -}}
      {{- if $first }}{{- $first = false }}{{ else }},{{ end }}
        "{{ $rule.pattern }}": {{ $value }}
    {{- end -}}
  {{- end -}}
{{- end }}
