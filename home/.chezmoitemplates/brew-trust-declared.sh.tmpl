# Homebrew tap trust helper generated by chezmoi.
# Trust only explicitly-declared third-party tap formulae/casks from a rendered Brewfile.
trust_declared_brew_tap_packages() {
  local brewfile="$1"
  local line type name

  while IFS= read -r line; do
    type="${line%% *}"
    name="${line#*\"}"
    name="${name%%\"*}"
    case "$type:$name" in
      brew:*/*/*)
        brew trust --formula "$name"
        ;;
      cask:*/*/*)
        brew trust --cask "$name"
        ;;
    esac
  done < <(grep -E '^(brew|cask) "[^/]+/[^/]+/[^/]+"' "$brewfile" || true)
}
