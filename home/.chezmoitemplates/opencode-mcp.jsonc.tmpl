{{- /* Render OpenCode MCP entries (eligible servers + resolved args from shared partial). */ -}}
{{- $eligible := includeTemplate ".chezmoitemplates/mcp-eligible-servers.tmpl" (dict "ctx" . "target" "opencode") | fromJson -}}
{{- $first := true -}}
{{- range $serverId := (keys $eligible | sortAlpha) -}}
  {{- $server := index $eligible $serverId -}}
  {{- if $first }}{{- $first = false }}{{ else }},{{ end }}
    "{{ $serverId }}": {
      {{- if hasKey $server "local" -}}
        {{- $openCodeCommand := prepend $server.local.args $server.local.command }}
      "type": {{ "local" | toJson }},
      "command": {{ $openCodeCommand | toPrettyJson | indent 6 | trim }},
      {{- else if hasKey $server "remote" }}
      "type": {{ "remote" | toJson }},
      "url": {{ $server.remote.url | toJson }},
      {{- end }}
      "enabled": true
    }
{{- end }}
