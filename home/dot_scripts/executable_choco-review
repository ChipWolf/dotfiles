#!/usr/bin/env bash
# choco-review — interactive Chocolatey drift review
#
# Compares what is actually installed via Chocolatey against packages declared
# in the chezmoi Chocolatey overlay data. Prompts for each package that is
# installed but not declared.
#
# Usage: choco-review [<ignorefile-path>]
#
# Exits silently if there is no drift or if stdin is not a tty.

set -uo pipefail

# Skip entirely when not interactive
if [ ! -t 0 ]; then
	exit 0
fi

CHEZMOI_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$(chezmoi source-path 2>/dev/null || echo "$HOME/.local/share/chezmoi/home")}"
CHOCO_DATA_DIR="$CHEZMOI_SOURCE_DIR/.chezmoidata/chocolatey"
CHOCO_PACKAGES_TMPL="$CHEZMOI_SOURCE_DIR/.chezmoitemplates/choco-packages.config.tmpl"
IGNOREFILE="${1:-$CHEZMOI_SOURCE_DIR/Chocofile.ignore}"

if [ ! -f "$CHOCO_PACKAGES_TMPL" ]; then
	echo "choco-review: Chocolatey packages template not found at $CHOCO_PACKAGES_TMPL" >&2
	exit 1
fi
if [ ! -d "$CHOCO_DATA_DIR" ]; then
	echo "choco-review: Chocolatey overlay data not found under $CHOCO_DATA_DIR" >&2
	exit 1
fi

CHOCO_BACKEND=""
CHOCO_BIN=""

if command -v choco >/dev/null 2>&1; then
	CHOCO_BACKEND="direct"
	CHOCO_BIN="$(command -v choco)"
elif command -v choco.exe >/dev/null 2>&1; then
	CHOCO_BACKEND="direct"
	CHOCO_BIN="$(command -v choco.exe)"
elif command -v cmd.exe >/dev/null 2>&1; then
	CHOCO_BACKEND="cmd.exe"
else
	echo "choco-review: could not find choco, choco.exe, or cmd.exe" >&2
	exit 1
fi

_choco() {
	if [ "$CHOCO_BACKEND" = "direct" ]; then
		"$CHOCO_BIN" "$@"
		return $?
	fi

	local cmdline="choco"
	local arg
	for arg in "$@"; do
		cmdline="$cmdline $arg"
	done
	cmd.exe /d /s /c "$cmdline"
}

_declared_packages() {
	if ! command -v chezmoi >/dev/null 2>&1; then
		echo "choco-review: chezmoi CLI is required to render declared packages" >&2
		return 1
	fi
	if ! chezmoi execute-template --file "$CHOCO_PACKAGES_TMPL" >"$declared_config_tmp"; then
		echo "choco-review: failed to render declared packages from $CHOCO_PACKAGES_TMPL" >&2
		return 1
	fi

	awk '
    {
      line = $0
      while (match(line, /id="[^"]+"/)) {
        pkg = substr(line, RSTART, RLENGTH)
        sub(/^id="/, "", pkg)
        sub(/"$/, "", pkg)
        pkg = tolower(pkg)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", pkg)
        if (pkg != "") print pkg
        line = substr(line, RSTART + RLENGTH)
      }
    }
  ' "$declared_config_tmp" | sort -u
}

_installed_packages() {
	_choco list --local-only --limit-output --no-color 2>/dev/null |
		tr -d '\r' |
		awk -F'|' '
      /\|/ {
        pkg = tolower($1)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", pkg)
        if (pkg != "") print pkg
      }
    ' | sort -u
}

_resolve_choco_lib_dir() {
	local -a candidates=()
	if [ -n "${ChocolateyInstall:-}" ]; then
		candidates+=("$ChocolateyInstall/lib")
		if command -v cygpath >/dev/null 2>&1; then
			candidates+=("$(cygpath -u "$ChocolateyInstall")/lib")
		fi
	fi
	candidates+=(
		"/c/ProgramData/chocolatey/lib"
		"/cygdrive/c/ProgramData/chocolatey/lib"
		"/mnt/c/ProgramData/chocolatey/lib"
	)

	local dir
	for dir in "${candidates[@]}"; do
		[ -z "$dir" ] && continue
		if [ -d "$dir" ]; then
			printf '%s\n' "$dir"
			return 0
		fi
	done
	return 1
}

_dependency_packages() {
	local lib_dir
	lib_dir="$(_resolve_choco_lib_dir)" || return 0

	local -a nuspecs=()
	shopt -s nullglob
	nuspecs=("$lib_dir"/*/*.nuspec)
	shopt -u nullglob
	if [ ${#nuspecs[@]} -eq 0 ]; then
		return 0
	fi

	awk '
    {
      line = $0
      while (match(line, /<dependency[^>]*id="[^"]+"/)) {
        dep = substr(line, RSTART, RLENGTH)
        sub(/^.*id="/, "", dep)
        sub(/"$/, "", dep)
        dep = tolower(dep)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", dep)
        if (dep != "") print dep
        line = substr(line, RSTART + RLENGTH)
      }
    }
  ' "${nuspecs[@]}" | sort -u
}

_has_parent_package_installed() {
	local pkg="$1"
	local suffix=""
	case "$pkg" in
	*.install)
		suffix=".install"
		;;
	*.portable)
		suffix=".portable"
		;;
	*)
		return 1
		;;
	esac

	local parent="${pkg%$suffix}"
	[ -n "$parent" ] || return 1
	echo "$installed_packages" | grep -qxF "$parent"
}

_ignore_packages() {
	if [ ! -f "$IGNOREFILE" ]; then
		return 0
	fi

	awk '
    /^[[:space:]]*#/ { next }
    /^[[:space:]]*$/ { next }
    {
      pkg = tolower($1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", pkg)
      if (pkg != "") print pkg
    }
  ' "$IGNOREFILE" | sort -u
}

_default_overlay_file() {
	local -a files=()
	shopt -s nullglob
	files=("$CHOCO_DATA_DIR"/*.yaml)
	shopt -u nullglob
	if [ ${#files[@]} -eq 0 ]; then
		return 1
	fi

	local file
	for file in "${files[@]}"; do
		if awk '
      /^[[:space:]]{4}base:[[:space:]]*$/ { found = 1 }
      END { exit(found ? 0 : 1) }
    ' "$file"; then
			printf '%s\n' "$file"
			return 0
		fi
	done

	printf '%s\n' "${files[0]}"
	return 0
}

_append_package_to_overlay() {
	local pkg="$1"
	local overlay_file
	overlay_file="$(_default_overlay_file)" || return 1
	printf '        - %s\n' "$pkg" >>"$overlay_file"
}

declared_config_tmp="$(mktemp)"
cleanup() {
	rm -f "$declared_config_tmp"
}
trap cleanup EXIT INT TERM

if ! declared_packages="$(_declared_packages)"; then
	exit 1
fi
installed_packages="$(_installed_packages)"
dependency_packages="$(_dependency_packages)"
ignore_packages="$(_ignore_packages)"

extras=()
while IFS= read -r pkg; do
	[ -z "$pkg" ] && continue
	if echo "$dependency_packages" | grep -qxF "$pkg"; then
		continue
	fi
	if _has_parent_package_installed "$pkg"; then
		continue
	fi
	if ! echo "$declared_packages" | grep -qxF "$pkg"; then
		if ! echo "$ignore_packages" | grep -qxF "$pkg"; then
			extras+=("$pkg")
		fi
	fi
done <<<"$installed_packages"

if [ ${#extras[@]} -eq 0 ]; then
	exit 0
fi

echo ""
echo "==> Chocolatey drift review"
echo ""
echo "The following packages are installed but not declared:"
echo ""

for pkg in "${extras[@]}"; do
	if ! _choco list --local-only --exact "$pkg" --limit-output --no-color >/dev/null 2>&1; then
		echo "  (skipping $pkg — already removed)"
		echo ""
		continue
	fi

	printf "  %s\n" "$pkg"
	while true; do
		printf "  [a]dd to chocolatey overlays / [r]emove / [i]gnore permanently / [s]kip: "
		read -r reply </dev/tty
		case "$reply" in
		a | A)
			if _append_package_to_overlay "$pkg"; then
				echo "  -> Added $pkg to chocolatey overlay data"
			else
				echo "  -> Failed to add $pkg to chocolatey overlay data" >&2
			fi
			break
			;;
		r | R)
			if _choco uninstall "$pkg" -y --no-progress --limit-output --no-color; then
				echo "  -> Removed $pkg"
			else
				echo "  -> Failed to remove $pkg" >&2
			fi
			break
			;;
		i | I)
			# shellcheck disable=SC2094
			{
				[ -f "$IGNOREFILE" ] || echo "# Chocofile.ignore — managed by chezmoi"
				echo "$pkg"
			} >>"$IGNOREFILE"
			echo "  -> Added to $IGNOREFILE"
			break
			;;
		s | S | "")
			echo "  -> Skipped"
			break
			;;
		*)
			echo "  Please enter a, r, i, or s."
			;;
		esac
	done
	echo ""
done
