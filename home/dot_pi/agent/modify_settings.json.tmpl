#!/usr/bin/env python3
# chezmoi modify_ script: declaratively manage the `packages` array in
# ~/.pi/agent/settings.json without clobbering runtime fields like
# `lastChangelogVersion`, `defaultProvider`, `defaultModel`, etc.
#
# Stdin: current contents of ~/.pi/agent/settings.json (empty on first apply).
# Stdout: merged JSON written back to the target.
#
# Edit the `declared_packages` list below (rendered via chezmoi templating)
# to declare which pi packages should be installed globally.
import json, sys

declared_packages = {{ list
  "npm:context-mode"
  "npm:pi-mcp-adapter"
  "npm:pi-subagents"
  "npm:pi-lens"
| toJson }}

raw = sys.stdin.read().strip()
try:
    data = json.loads(raw) if raw else {}
except json.JSONDecodeError:
    data = {}

if not isinstance(data, dict):
    data = {}

data["packages"] = declared_packages

json.dump(data, sys.stdout, indent=2)
sys.stdout.write("\n")
