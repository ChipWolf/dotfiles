{{- /* chezmoi:modify-template */ -}}
{{- $root := . -}}
{{- $merged := dict -}}
{{- if .chezmoi.stdin -}}
  {{- $parsed := fromJson .chezmoi.stdin -}}
  {{- if kindIs "map" $parsed -}}
    {{- $merged = $parsed -}}
  {{- end -}}
{{- end -}}
{{- $_ := set $merged "packages" (list
  "npm:context-mode"
  "npm:pi-mcp-adapter"
  "npm:pi-subagents"
  "npm:pi-lens"
) -}}
{{- $merged | toPrettyJson }}
