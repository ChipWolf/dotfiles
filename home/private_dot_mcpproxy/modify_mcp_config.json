{{- /* chezmoi:modify-template */ -}}
{{- $merged := includeTemplate ".chezmoitemplates/modify-stdin.tmpl" . | fromJson -}}

{{- /* Drop deprecated fields that mcpproxy 0.29+ removes on first run. */ -}}
{{- $_ := unset $merged "top_k" -}}
{{- $_ := unset $merged "enable_tray" -}}
{{- $_ := unset $merged "features" -}}

{{- $_ := set $merged "listen" "127.0.0.1:8080" -}}
{{- $_ := set $merged "data_dir" (printf "%s/.mcpproxy" .chezmoi.homeDir) -}}
{{- $_ := set $merged "tools_limit" 15 -}}
{{- $_ := set $merged "tool_response_limit" 20000 -}}

{{- /* Build declarative MCP server list from merged chezmoidata.
       Eligible servers + resolved args come from the shared prep partial. */ -}}
{{- $servers := list -}}
{{- $eligible := includeTemplate ".chezmoitemplates/mcp-eligible-servers.tmpl" (dict "ctx" . "target" "mcpproxy") | fromJson -}}
{{- range $serverId := (keys $eligible | sortAlpha) -}}
  {{- $server := index $eligible $serverId -}}
  {{- if hasKey $server "local" -}}
    {{- $entry := dict
          "name" $serverId
          "protocol" "stdio"
          "command" $server.local.command
          "args" $server.local.args
          "enabled" true -}}
    {{- if and (hasKey $server.local "env") $server.local.env -}}
      {{- $_ := set $entry "env" $server.local.env -}}
    {{- end -}}
    {{- $servers = append $servers $entry -}}
  {{- else if hasKey $server "remote" -}}
    {{- $proxyProtocol := "streamable-http" -}}
    {{- if hasKey $server.remote "transport" -}}
      {{- $t := $server.remote.transport -}}
      {{- if eq $t "streamableHttp" -}}{{- $proxyProtocol = "streamable-http" -}}
      {{- else if eq $t "http" -}}{{- $proxyProtocol = "http" -}}
      {{- else if eq $t "sse" -}}{{- $proxyProtocol = "sse" -}}
      {{- else -}}{{- $proxyProtocol = $t -}}
      {{- end -}}
    {{- end -}}
    {{- $entry := dict
          "name" $serverId
          "protocol" $proxyProtocol
          "url" $server.remote.url
          "enabled" true -}}
    {{- if and (hasKey $server.remote "headers") $server.remote.headers -}}
      {{- $_ := set $entry "headers" $server.remote.headers -}}
    {{- end -}}
    {{- $servers = append $servers $entry -}}
  {{- end -}}
{{- end }}
{{- $_ := set $merged "mcpServers" $servers -}}
{{- $merged | toPrettyJson }}
