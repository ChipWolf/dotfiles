{{- if eq .chezmoi.os "windows" -}}
{{- if hasKey . "skills" -}}
# Re-run when the declared skills manifest changes.
# {{ include ".chezmoidata/skills/00-skills.yaml" | sha256sum }}
$ErrorActionPreference = "Stop"

if (-not (Get-Command mise -ErrorAction SilentlyContinue)) {
    throw "mise not found on PATH; run bootstrap first."
}
{{- if and (not .codespaces) (not .ci) }}
{{ $defaults := .skills.defaults }}
{{- $sources := .skills.sources }}
{{- range $sourceId := (keys $sources | sortAlpha) }}
{{- $source := index $sources $sourceId }}
{{- $targets := $defaults.targets }}
{{- if hasKey $source "targets" }}{{ $targets = $source.targets }}{{ end }}
{{- $spec := "" }}
{{- if hasKey $source "path" }}{{ $spec = printf "%s/%s" $.chezmoi.workingTree $source.path }}
{{- else if hasKey $source "repo" }}{{ $spec = $source.repo }}
{{- end }}
{{- range $target := $targets }}
{{- if and (hasKey $source "skills") $source.skills }}
& mise x -- npx -y skills@latest add {{ $spec }} -a {{ $target }} -g -y -s '{{ join "," $source.skills }}'
{{- else }}
& mise x -- npx -y skills@latest add {{ $spec }} -a {{ $target }} -g -y -s '*'
{{- end }}
if ($LASTEXITCODE -ne 0) { throw "skills add {{ $spec }} -a {{ $target }} failed (exit code $LASTEXITCODE)." }
{{- end }}
{{- end }}
{{- end }}

# Prune legacy skill junctions created by earlier dotfiles gap-fill logic. The
# vercel-labs/skills CLI owns per-agent distribution; these extra junctions can
# create duplicate discovery paths in agents that already read ~/.agents\skills.
# Safety: only remove links that point under ~/.agents\skills.
$canonicalSkillsDir = Join-Path $env:USERPROFILE ".agents\skills"
$legacyGapAgentDirs = @(
    (Join-Path $env:USERPROFILE ".codex\skills"),
    (Join-Path $env:USERPROFILE ".cursor\skills"),
    (Join-Path $env:USERPROFILE ".config\opencode\skills")
)
foreach ($agentDir in $legacyGapAgentDirs) {
    if (-not (Test-Path $agentDir)) { continue }
    $links = Get-ChildItem $agentDir -Force -ErrorAction SilentlyContinue |
        Where-Object { $_.LinkType -eq "Junction" -or $_.LinkType -eq "SymbolicLink" }
    foreach ($link in $links) {
        $target = @($link.Target)[0]
        if ($target) {
            $targetPath = [System.IO.Path]::GetFullPath($target).TrimEnd('\')
            $canonicalPath = [System.IO.Path]::GetFullPath($canonicalSkillsDir).TrimEnd('\')
            if ($targetPath.StartsWith($canonicalPath + '\', [System.StringComparison]::OrdinalIgnoreCase)) {
                Remove-Item $link.FullName -Force
            }
        }
    }
}
{{ end -}}
{{ end -}}
