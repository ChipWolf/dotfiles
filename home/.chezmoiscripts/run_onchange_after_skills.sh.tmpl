{{ if ne .chezmoi.os "windows" -}}
{{- if hasKey . "skills" -}}
#!/usr/bin/env bash
# Re-run when the declared skills manifest changes.
# {{ include ".chezmoidata/skills/00-skills.yaml" | sha256sum }}
set -euo pipefail

# Ensure brew-installed mise is on PATH for non-interactive shells (matches
# the pattern in run_onchange_after_mise_install.sh.tmpl). Cloud-init's runcmd
# environment in WSL has a minimal PATH that excludes brew prefixes.
for prefix in /opt/homebrew /usr/local /home/linuxbrew/.linuxbrew "$HOME/.linuxbrew"; do
  if [ -x "$prefix/bin/mise" ]; then
    export PATH="$prefix/bin:$PATH"
    break
  fi
done

# Then add mise shims so npx (via the mise-managed node) is on PATH.
export PATH="$HOME/.local/share/mise/shims:$PATH"

if ! command -v mise >/dev/null 2>&1; then
  echo "mise not found on PATH; run bootstrap first" >&2
  exit 1
fi
{{- if and (not .codespaces) (not .ci) }}
{{ $defaults := .skills.defaults }}
{{- $sources := .skills.sources }}
{{- range $sourceId := (keys $sources | sortAlpha) }}
{{- $source := index $sources $sourceId }}
{{- $targets := $defaults.targets }}
{{- if hasKey $source "targets" }}{{ $targets = $source.targets }}{{ end }}
{{- $spec := "" }}
{{- if hasKey $source "path" }}{{ $spec = printf "%s/%s" $.chezmoi.workingTree $source.path }}
{{- else if hasKey $source "repo" }}{{ $spec = $source.repo }}
{{- end }}
{{- range $target := $targets }}
{{- if and (eq $target "hermes-agent") (or (ne $.chezmoi.os "darwin") (not $.private)) }}{{- continue }}{{- end }}
{{- if and (hasKey $source "skills") $source.skills }}
mise x -- npx -y skills@latest add {{ $spec }} -a {{ $target }} -g -y -s '{{ join "," $source.skills }}'
{{- else }}
mise x -- npx -y skills@latest add {{ $spec }} -a {{ $target }} -g -y -s '*'
{{- end }}
{{- end }}
{{- end }}
{{- end }}

canonical_skills_dir="$HOME/.agents/skills"

# Prune legacy skill links created by earlier dotfiles gap-fill logic. The
# vercel-labs/skills CLI owns per-agent distribution; these extra links can
# create duplicate discovery paths in agents that already read ~/.agents/skills.
# Safety: only remove symlinks that point under ~/.agents/skills.
legacy_gap_agent_dirs=(
    "$HOME/.codex/skills"
    "$HOME/.cursor/skills"
    "${XDG_CONFIG_HOME:-$HOME/.config}/opencode/skills"
)
for agent_dir in "${legacy_gap_agent_dirs[@]}"; do
    [ -d "$agent_dir" ] || continue
    for link_path in "$agent_dir"/*; do
        [ -L "$link_path" ] || continue
        target=$(readlink "$link_path")
        case "$target" in
            "$canonical_skills_dir"/*) rm "$link_path" ;;
        esac
    done
done

# Prune pi skill duplicates left behind on machines that previously had pi
# in defaults.targets (the skills CLI copied skills into ~/.pi/agent/skills/
# and pi reads that location as well as ~/.agents/skills/, producing
# name-collision warnings at startup).
#
# Safety: only remove a ~/.pi/agent/skills/<name> when its contents are
# byte-identical to ~/.agents/skills/<name>. A pi extension that writes a
# same-named skill with different content is left alone.
pi_skills_dir="$HOME/.pi/agent/skills"
if [ -d "$pi_skills_dir" ] && [ -d "$canonical_skills_dir" ]; then
    for skill_path in "$pi_skills_dir"/*; do
        [ -d "$skill_path" ] || continue
        skill_name=$(basename "$skill_path")
        case "$skill_name" in .*) continue ;; esac
        canonical_path="$canonical_skills_dir/$skill_name"
        [ -d "$canonical_path" ] || continue
        if diff -rq "$skill_path" "$canonical_path" >/dev/null 2>&1; then
            rm -rf "$skill_path"
        fi
    done
fi
{{ end -}}
{{ end -}}
