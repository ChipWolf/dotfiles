{{ if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# Re-run when declared pi packages change.
# {{ include "dot_pi/agent/modify_settings.json" | sha256sum }}
set -euo pipefail

# Use mise shims so pi (installed via npm: backend) is on PATH for
# non-interactive shells run by chezmoi.
export PATH="$HOME/.local/share/mise/shims:$PATH"

if ! command -v pi >/dev/null 2>&1; then
  echo "pi not found on PATH; run 'mise install' first" >&2
  exit 1
fi

# pi auto-installs missing packages declared in settings on startup, but we
# trigger an explicit reconcile here so apply-time errors surface immediately.
pi update --extensions
{{ end -}}
